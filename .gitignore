# pyenv
#   For a library or binary, you shouldn't ignore these files, but for a specific project
#   where you want to fix the python version, you can uncomment them.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you want to create your own pipenv from Pipfile,
#   uncomment these lines:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock
#   python-project.toml

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm build/
.pdm-plugins/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

