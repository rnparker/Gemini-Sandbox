graph TD
    subgraph "PR Event Trigger"
        A["Pull Request Event"] --> B{"Action Type?"}
        B -- "opened / synchronize / reopened" --> C("Job: generate-preview")
        B -- "closed" --> D("Job: cleanup-preview")
    end

    subgraph "Generation Logic"
        C --> C1["Checkout PR Branch"]
        C1 --> C2["Create docs/previews/pr-{{num}}"]
        C2 --> C3["Run pulse_check.py"]
        C3 --> C4["Switch to 'main' & Push Preview"]
        C4 --> C5["Post/Update Sticky PR Comment"]
    end

    subgraph "Cleanup Logic"
        D --> D1["Checkout 'main' Branch"]
        D1 --> D2["git rm -rf docs/previews/pr-{{num}}"]
        D2 --> D3["Commit & Push to 'main'"]
        D3 --> D4["Delete Sticky PR Comment"]
    end

    subgraph "Hosting"
        C4 -.-> E["GitHub Pages (main branch /docs)"]
        D3 -.-> E
    end
